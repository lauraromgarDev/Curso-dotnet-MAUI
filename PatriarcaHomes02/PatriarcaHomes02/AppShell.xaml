<Shell
    x:Class="PatriarcaHomes02.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:PatriarcaHomes02.Views"
    Title="Patriarca Homes">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginView}"
        Route="LoginView" />

    <ShellContent
        Title="Reservas"
        ContentTemplate="{DataTemplate views:ReservasMainView}"
        Route="ReservasMainView" />

    <MenuItem Command="{Binding LogoutAppCommand}" Text="Cerrar Sesión" />

</Shell>