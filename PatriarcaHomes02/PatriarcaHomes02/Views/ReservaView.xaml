<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PatriarcaHomes02.Views.ReservaView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:PatriarcaHomes02.ViewModels"
    Title="ReservaView"
    x:DataType="viewModels:ReservaFormViewModel">
    <Grid
        Padding="20"
        ColumnDefinitions="*"
        RowDefinitions="Auto, Auto, Auto,  Auto, Auto">
        <Label
            Grid.Row="0"
            FontAttributes="Bold"
            Text="Fecha de la Reserva" />

        <DatePicker
            Grid.Row="1"
            Margin="0,0,0,20"
            Date="{Binding Item.Fecha}" />

        <Label
            Grid.Row="2"
            FontAttributes="Bold"
            Text="Usuario ID" />

        <Entry
            Grid.Row="3"
            Keyboard="Numeric"
            Placeholder="Introduce el ID..."
            Text="{Binding Item.User_id}" />

        <Button
            Grid.Row="4"
            Margin="20"
            Background="Brown"
            Command="{Binding SaveReservaCommand}"
            Text="Guardar" />

    </Grid>
</ContentPage>