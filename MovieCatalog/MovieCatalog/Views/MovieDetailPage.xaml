<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MovieCatalog.Views.MovieDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MovieCatalog.ViewModels"
    Title="MovieDetailPage">
    <Grid
        Margin="10"
        ColumnDefinitions="Auto,*"
        RowDefinitions="Auto,Auto,Auto,Auto">
        <Label Grid.Row="0" Text="Title:" />
        <Label Grid.Row="1" Text="Year:" />
        <Label Grid.Row="2" Text="Studio:" />
        <Label
            Grid.Row="3"
            Margin="0,0,5,0"
            Text="Director:" />

        <Label
            Grid.Row="0"
            Grid.Column="1"
            Text="{Binding Title}" />
        <Label
            Grid.Row="1"
            Grid.Column="1"
            Text="{Binding Year, StringFormat='{0:yyyy}'}" />
        <Label
            Grid.Row="2"
            Grid.Column="1"
            Text="{Binding Studio}" />
        <Label
            Grid.Row="3"
            Grid.Column="1"
            Text="{Binding Director}" />
    </Grid>
</ContentPage>